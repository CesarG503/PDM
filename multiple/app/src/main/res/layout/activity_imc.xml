<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".IMC">

    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="409dp"
        android:layout_height="339dp"
        android:layout_marginEnd="2dp"
        android:layout_marginBottom="392dp"
        app:columnCount="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:rowCount="10">

        <TextView
            android:id="@+id/textView6"
            android:layout_width="87dp"
            android:layout_height="wrap_content"
            android:text="Peso"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_row="0" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="87dp"
            android:layout_height="wrap_content"
            android:text="Altura"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_row="1" />

        <EditText
            android:id="@+id/peso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Ingresa tu Peso"
            android:inputType="text"
            app:layout_column="1"
            app:layout_row="0" />

        <EditText
            android:id="@+id/altura"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Ingresa tu altura"
            android:inputType="text"
            app:layout_column="1"
            app:layout_row="1" />

        <RadioGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_column="1"
            app:layout_row="4" />

        <RadioButton
            android:id="@+id/btn_metrico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Metrico"
            app:layout_column="1"
            app:layout_row="2"
            app:layout_rowSpan="2" />

        <RadioButton
            android:id="@+id/btn_imperial"
            android:layout_width="207dp"
            android:layout_height="116dp"
            android:checked="false"
            android:text="Imperial"
            app:layout_column="1"
            app:layout_row="2"
            />

        <Button
            android:id="@+id/calcular"
            android:layout_width="210dp"
            android:layout_height="wrap_content"
            android:text="CALCULAR"
            app:layout_column="1"
            app:layout_row="5"
            android:onClick="calcular"/>
    </androidx.gridlayout.widget.GridLayout>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="53dp"
        android:layout_marginEnd="46dp"
        android:layout_marginBottom="211dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/IMC"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gridLayout"
        app:layout_constraintVertical_bias="0.0"
        tools:srcCompat="@tools:sample/avatars" />

    <TextView
        android:id="@+id/IMC"
        android:layout_width="74dp"
        android:layout_height="36dp"
        android:layout_marginTop="102dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="270dp"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/categoria"
        app:layout_constraintTop_toBottomOf="@+id/gridLayout" />

    <TextView
        android:id="@+id/categoria"
        android:layout_width="73dp"
        android:layout_height="37dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="104dp"
        android:layout_marginBottom="269dp"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/IMC"
        app:layout_constraintTop_toBottomOf="@+id/gridLayout"
        app:layout_constraintVertical_bias="0.571" />
</androidx.constraintlayout.widget.ConstraintLayout>